{
  "info": {
    "name": "Spring Boot TODO Application",
    "description": "Postman collection for the session 4 TODO REST API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create TODO",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Complete assignment\",\n  \"description\": \"Build Spring Boot TODO application\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/todos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos"
          ]
        }
      }
    },
    {
      "name": "Get All TODOs",
      "request": {
        "method": "GET",
        "header": [],
