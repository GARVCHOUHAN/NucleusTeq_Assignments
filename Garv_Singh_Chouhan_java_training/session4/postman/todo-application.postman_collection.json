    },
    {
      "name": "Delete TODO",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/todos/1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos",
            "1"
          ]
        }
