          "raw": "{{baseUrl}}/todos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos"
          ]
        }
      }
    },
    {
      "name": "Get TODO by ID",
      "request": {
        "method": "GET",
        "header": [],
